# Active LLM provider: gemini | groq | mistral | claude | openai
LLM_PROVIDER=gemini

# --- API keys (fill in the one(s) you use) ---
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Server
PORT=8000

# Comma-separated list of allowed CORS origins for production (optional).
# Local dev origins are always allowed.
CORS_ORIGINS=
