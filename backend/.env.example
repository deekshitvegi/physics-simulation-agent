# Active LLM provider: gemini | groq | mistral | claude | openai | ollama
LLM_PROVIDER=gemini

# --- API keys (fill in the one(s) you use) ---
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Ollama: run a model locally, free & unlimited, no key ---
# Install from https://ollama.com, run `ollama pull llama3.1`, then set
# LLM_PROVIDER=ollama above. Optional overrides:
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434/v1

# Server
PORT=8000

# Comma-separated list of allowed CORS origins for production (optional).
# Local dev origins are always allowed.
CORS_ORIGINS=
